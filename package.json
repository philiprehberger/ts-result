{
  "name": "@philiprehberger/result",
  "version": "0.4.0",
  "description": "Rust-inspired Result type for type-safe error handling without try/catch",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "result",
    "either",
    "error-handling",
    "type-safe",
    "typescript",
    "monad"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-result.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-result#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-result/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
